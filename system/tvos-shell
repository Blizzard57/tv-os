#!/usr/bin/env bash
# Runs INSIDE gamescope (started by tvos-session). Starts the daemon in the
# background, then runs the kiosk browser as the session's foreground app.
#
# Because tvosd is started here, everything it launches (Steam, mpv) inherits
# gamescope's display and appears on the TV in front of the shell.
set -euo pipefail

URL="http://127.0.0.1:8484"

"$HOME/.local/bin/tvosd" &
TVOSD_PID=$!
trap 'kill "$TVOSD_PID" 2>/dev/null || true' EXIT

# Give the daemon a moment to come up before pointing the browser at it.
for _ in $(seq 1 50); do
  if curl -fsS "$URL/api/library" >/dev/null 2>&1; then
    break
  fi
  sleep 0.2
done

# Find a Chromium-family browser for the kiosk UI (same list as tvos-app so
# both entry points cover the same browsers).
pick_browser() {
  local b f
  for b in chromium chromium-browser google-chrome google-chrome-stable \
           brave brave-browser vivaldi-stable microsoft-edge-stable; do
    command -v "$b" >/dev/null 2>&1 && { BROWSER=("$b"); return 0; }
  done
  for f in org.chromium.Chromium com.brave.Browser com.google.Chrome; do
    flatpak info "$f" >/dev/null 2>&1 && { BROWSER=(flatpak run "$f"); return 0; }
  done
  return 1
}
if ! pick_browser; then
  echo "tvos-shell: no Chromium-family browser found." >&2
  echo "Install one, e.g.: flatpak install flathub org.chromium.Chromium" >&2
  exit 1
fi

# gamescope is a Wayland compositor; run the browser natively on Wayland so
# HDR/VRR pass through (x11 here would force XWayland and undermine them).
exec "${BROWSER[@]}" \
  --kiosk "$URL" \
  --no-first-run \
  --disable-session-crashed-bubble \
  --password-store=basic \
  --ozone-platform=wayland
