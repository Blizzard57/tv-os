# TV OS — Arch/CachyOS package.
# Build & install from a clone of this repo:
#
#   cd packaging
#   makepkg -si
#
# This builds the daemon + UI and installs a real, pacman-managed package
# (uninstall with: sudo pacman -R tvos).
pkgname=tvos
pkgver=0.6.0
pkgrel=1
pkgdesc="Couch interface for all your games, movies and shows"
arch=('x86_64')
url="https://example.invalid/tvos"
license=('MIT')
depends=('gcc-libs')
optdepends=(
  'chromium: app window (or any Chromium-family browser)'
  'mpv: video playback with the Enhance upscaler'
  'gamescope: big-screen / controller mode (tvos-app --tv)'
  'ffmpeg: source-resolution probing for upscaling'
  'steam: Steam games'
  'retroarch: retro emulation'
  'unzip: shader pack extraction'
)
makedepends=('rust' 'cargo' 'npm' 'curl')
source=()

# Build straight from the working tree this PKGBUILD lives in.
_repo() { cd "$startdir/.."; }

pkgver() {
  _repo
  grep '^version' tvosd/Cargo.toml | head -1 | cut -d'"' -f2
}

build() {
  _repo
  ( cd tvosd && cargo build --release )
  ( cd shell && npm ci && npm run build )
}

package() {
  _repo
  install -Dm755 tvosd/target/release/tvosd "$pkgdir/usr/bin/tvosd"
  install -Dm755 system/tvos-app            "$pkgdir/usr/bin/tvos-app"

  install -dm755 "$pkgdir/usr/share/tvos/ui"
  cp -r shell/dist/* "$pkgdir/usr/share/tvos/ui/"

  install -Dm644 system/tvos.svg \
    "$pkgdir/usr/share/icons/hicolor/scalable/apps/tvos.svg"
  install -Dm644 packaging/tvos.desktop \
    "$pkgdir/usr/share/applications/tvos.desktop"
}
